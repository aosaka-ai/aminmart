rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // Role-based helpers
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "a.osaka@gmail.com" && isEmailVerified())
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection Schemas & Rules ---

    // USERS COLLECTION
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'role']) &&
               data.uid == userId &&
               data.role in ['admin', 'customer'] &&
               (data.get('email', null) == null || data.email is string);
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.role == resource.data.role; // Prevent self-elevation
      allow delete: if isAdmin();
    }

    // STAFF CREDENTIALS
    // Access is based on Employee ID as the document ID
    match /staffCredentials/{employeeId} {
      function isValidCredential(data) {
        return data.keys().hasAll(['uid', 'employeeId', 'password']) &&
               data.uid is string &&
               data.employeeId == employeeId &&
               data.password is string && data.password.size() >= 6;
      }

      // Allow login lookups
      allow get: if true;
      allow list: if isAdmin(); // Needed for fallback query search
      
      allow create: if isAdmin() && isValidCredential(request.resource.data);
      allow update: if isAdmin() && 
                    isValidCredential(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid; // Bound to same user
      allow delete: if isAdmin();
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      // Allow users to decrement stock during purchase (simplified for prototype)
      allow update: if isSignedIn() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']);
    }

    // ORDERS
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.userId == request.auth.uid &&
               data.total is number && data.total > 0 &&
               data.status in ['pending', 'confirmed', 'out-for-delivery', 'delivered'];
      }

      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidOrder(request.resource.data);
      allow update: if isAdmin() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }
  }
}
