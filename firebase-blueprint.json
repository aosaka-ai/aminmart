{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "description": "Supermarket product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "categoryId": { "type": "string" },
        "unit": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "stock", "categoryId"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "employeeId": { "type": "string" },
        "addresses": { "type": "array" }
      },
      "required": ["uid", "role"]
    },
    "StaffCredential": {
      "title": "Staff Credential",
      "description": "Secure login credentials for staff",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "employeeId": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["uid", "employeeId", "password"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["userId", "total", "status", "items"]
    }
  },
  "firestore": {
    "categories": { "schema": "Category", "description": "Product categories" },
    "products": { "schema": "Product", "description": "Supermarket products" },
    "users": { "schema": "UserProfile", "description": "User profiles" },
    "staffCredentials": { "schema": "StaffCredential", "description": "Staff login credentials" },
    "orders": { "schema": "Order", "description": "Customer orders" }
  }
}
