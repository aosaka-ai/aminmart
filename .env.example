# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Use VITE_ prefix if you need to expose a variable to the React client directly.
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=
# GOOGLE MAPS API KEY: Required for maps integration.
VITE_GOOGLE_MAPS_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLOUDINARY CONFIGURATION
# 1. Cloud Name (from Cloudinary Dashboard)
VITE_CLOUDINARY_CLOUD_NAME=
# 2. Upload Preset (from Settings > Upload > Upload presets)
# Make sure the preset is "Unsigned" to allow direct uploads from the app.
VITE_CLOUDINARY_UPLOAD_PRESET=
